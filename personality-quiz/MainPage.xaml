<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="personality_quiz.MainPage">

    <Grid RowDefinitions="*, Auto, Auto" RowSpacing="30" Padding="0,0,0,60">
        <Image
            Source="glowing_head.png"
            Aspect="AspectFill"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            SemanticProperties.Description="glowing head" />

        <Label
            x:Name="QuestionLabel"
            Grid.Row="1"
            Text="What's your personality type?"
            Style="{StaticResource Headline}"
            Margin="30,0"
            SemanticProperties.HeadingLevel="Level1" />

        <VerticalStackLayout Grid.Row="2" Spacing="15" Margin="30,0">
            <Button
                x:Name="StartBtn"
                Text="Start" 
                SemanticProperties.Hint="Starts the personality quiz"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill" />

            <HorizontalStackLayout x:Name="QuizButtons" IsVisible="False" Spacing="20" HorizontalOptions="Center">
                <Button
                    Text="True"
                    Clicked="OnTrueClicked"
                    WidthRequest="150" />
                <Button
                    Text="False"
                    Clicked="OnFalseClicked"
                    WidthRequest="150" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
