<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="personality_quiz.SettingsPage"
             Title="Settings">
    <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">
        <Label Text="Quiz Interaction Mode" 
               FontSize="24" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />
        
        <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
            <Label Text="Button" VerticalOptions="Center" FontSize="18" />
            <Switch x:Name="ModeSwitch" Toggled="OnModeToggled" />
            <Label Text="Swipe" VerticalOptions="Center" FontSize="18" />
        </HorizontalStackLayout>
        
        <Label x:Name="DescriptionLabel" 
               HorizontalOptions="Center" 
               TextColor="Gray"
               FontSize="14" />
    </VerticalStackLayout>
</ContentPage>
